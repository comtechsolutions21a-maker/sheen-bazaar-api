# =========================================================
# Sheen Bazaar — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to version control.
# =========================================================

PORT=5000

# MongoDB Atlas connection string (get one free at mongodb.com/atlas)
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/bazaario?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/bazaario

# Long random string used to sign JWTs — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# Your Netlify frontend URL (update after Step 2 of deployment)
# Example: https://sheen-bazaar.netlify.app
CLIENT_ORIGIN=http://localhost:5173

# =========================================================
# Optional: Real email notifications to sellers
# If left blank, notifications are printed to the server console only.
# =========================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sheen Bazaar <notifications@sheenbazaar.com>
